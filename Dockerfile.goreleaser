FROM alpine:latest AS certs
RUN apk add --no-cache ca-certificates

FROM tianon/toybox:0.8.13

ARG TARGETPLATFORM
COPY ${TARGETPLATFORM}/openlist-tvbox /usr/bin/openlist-tvbox
COPY --from=certs /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY LICENSE THIRD_PARTY_NOTICES.md /usr/share/doc/openlist-tvbox/
COPY licenses /usr/share/doc/openlist-tvbox/licenses

WORKDIR /config
ENV OPENLIST_TVBOX_CONFIG=config.yaml

EXPOSE 18989

ENTRYPOINT ["/usr/bin/openlist-tvbox"]
